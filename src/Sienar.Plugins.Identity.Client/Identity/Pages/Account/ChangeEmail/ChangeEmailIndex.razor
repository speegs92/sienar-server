@attribute [Route(DashboardUrls.Account.EmailChange.Index)]

<DocTitle Title="Change your email"/>

<NarrowContainer>
	<StandardForm
		T="InitiateEmailChangeRequest"
		OnSubmit="@OnSubmit"
		SubmitText="Update email"
		Title="Change email">
		<Fields>
			<Textbox
				bind-Value="@context.Email"
				For="() => context.Email"
				InputType="InputType.Email"
				Label="Enter your new email address"/>
			<Textbox
				bind-Value="@context.ConfirmEmail"
				For="() => context.ConfirmEmail"
				InputType="InputType.Email"
				Label="Confirm your new email address"/>
			<Textbox
				bind-Value="@context.ConfirmPassword"
				For="() => context.ConfirmPassword"
				InputType="InputType.Password"
				Label="Confirm your password"/>
		</Fields>
	</StandardForm>
</NarrowContainer>

@code {

	private static async Task OnSubmit(
		IStatusActor<InitiateEmailChangeRequest> emailChangeActor,
		InitiateEmailChangeRequest request,
		NavigationManager navManager)
	{
		var result = await emailChangeActor.Execute(request);

		if (result.Status is OperationStatus.Success)
		{
			navManager.NavigateTo(DashboardUrls.Account.EmailChange.Requested);
		}
	}

}
@attribute [Route(DashboardUrls.Account.PasswordChange.Index)]

<DocTitle Title="Change password"/>

<NarrowContainer>
	<StandardForm
		T="ChangePasswordRequest"
		OnSubmit="@OnSubmit"
		SubmitText="Update password"
		Title="Change password">
		<Information>
			<MudText>
				Please select a new password. Your new password should be at least 8 characters long and contain a mix of lowercase and uppercase letters, numbers, and special characters.
			</MudText>
		</Information>

		<Fields>
			<Textbox
				bind-Value="@context.NewPassword"
				For="() => context.NewPassword"
				InputType="InputType.Password"
				Label="Enter your new password"/>
			<Textbox
				bind-Value="@context.ConfirmNewPassword"
				For="() => context.ConfirmNewPassword"
				InputType="InputType.Password"
				Label="Re-enter your new password"/>
			<Textbox
				bind-Value="@context.CurrentPassword"
				For="() => context.CurrentPassword"
				InputType="InputType.Password"
				Label="Confirm your current password"/>
		</Fields>
	</StandardForm>
</NarrowContainer>

@code {

	private static async Task OnSubmit(
		IStatusActor<ChangePasswordRequest> passwordChangeActor,
		ChangePasswordRequest request,
		NavigationManager navManager)
	{
		var result = await passwordChangeActor.Execute(request);

		if (result.Status is OperationStatus.Success)
		{
			navManager.NavigateTo(DashboardUrls.Account.PasswordChange.Successful);
		}
	}

}
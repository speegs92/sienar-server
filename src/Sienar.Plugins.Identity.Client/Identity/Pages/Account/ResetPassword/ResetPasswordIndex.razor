@attribute [AllowAnonymous]
@attribute [Route(DashboardUrls.Account.ResetPassword.Index)]

<DocTitle Title="Reset Password"/>

<NarrowContainer>
	<StandardForm
		T="ResetPasswordRequest"
		OnSubmit="@OnSubmit"
		Title="Reset password"
		SubmitText="Reset my password">
		<Information>
			<MudText>
				Please select a new password for your account. Your password should be at least 8 characters long, and it should contain a mix of lowercase and uppercase letters, numbers, and special characters.
			</MudText>
		</Information>

		<Fields>
			<Textbox
				bind-Value="@context.NewPassword"
				For="() => context.NewPassword"
				InputType="InputType.Password"
				Label="New password"/>

			<Textbox
				bind-Value="@context.ConfirmNewPassword"
				For="() => context.ConfirmNewPassword"
				InputType="InputType.Password"
				Label="Confirm new password"/>

			<Honeypot @bind-Value="@context.SecretKeyField"/>
		</Fields>
	</StandardForm>
</NarrowContainer>


@code {

	/// <summary>
	/// The ID of the user whose password to reset
	/// </summary>
	[Parameter]
	[SupplyParameterFromQuery]
	public int UserId { get; set; }

	/// <summary>
	/// The verification code of the user whose password to reset
	/// </summary>
	[Parameter]
	[SupplyParameterFromQuery]
	public Guid Code { get; set; }

	private async Task OnSubmit(
		IStatusActor<ResetPasswordRequest> passwordResetActor,
		ResetPasswordRequest request,
		NavigationManager navManager)
	{
		request.UserId = UserId;
		request.VerificationCode = Code;

		var result = await passwordResetActor.Execute(request);

		if (result.Status is OperationStatus.Success)
		{
			navManager.NavigateTo(DashboardUrls.Account.ResetPassword.Successful);
		}
	}

}
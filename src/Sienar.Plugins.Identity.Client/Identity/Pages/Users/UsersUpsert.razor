@attribute [Authorize(Roles = Roles.Admin)]
@attribute [Route(DashboardUrls.Users.Add)]
@attribute [Route($"{DashboardUrls.Users.Index}/{{id:int}}")]
@* ReSharper disable once CollectionNeverUpdated.Local *@
@inject RoleProvider RoleProvider

<DocTitle Title="@Title"/>

<UpsertForm
	TViewDto="ViewUserDto"
	TUpsertDto="UpsertUserDto"
	EntityId="Id"
	Icon="@Icon"
	IconTitle="@($"{_user?.Username}'s email is confirmed")"
	OnUpdateSuccess="@OnSuccess"
	OnLoaded="@OnLoaded">
	<Fields>
		<Textbox
			@bind-Value="@context.Username"
			For="() => context.Username"
			Label="Username"/>
		<Textbox
			@bind-Value="@context.Email"
			For="() => context.Email"
			InputType="InputType.Email"
			Label="Email address"/>
		<Textbox
			@bind-Value="@context.Password"
			For="() => context.Password"
			InputType="InputType.Password"
			Label="Password"/>
		<Textbox
			@bind-Value="@context.ConfirmPassword"
			For="() => context.ConfirmPassword"
			InputType="InputType.Password"
			Label="Confirm password"/>

		@foreach (var role in RoleProvider.Order())
		{
			<Checkbox
				T="bool"
				Value="@context.Roles.Contains(role)"
				ValueChanged="inRole => UpdateRole(inRole, role, context)"
				Label="@role"/>
		}
	</Fields>

	<MoreActions>
		<MudButton
			Color="Color.Secondary"
			Variant="Variant.Outlined"
			Href="@DashboardUrls.Users.Index">
			Back to users listing
		</MudButton>
	</MoreActions>
</UpsertForm>

@code {

	private ViewUserDto? _user = new();

	private string? Icon => _user?.EmailConfirmed ?? false
		? Icons.Material.Filled.CheckCircle
		: null;

	private string Title => _user is not null
		? $"Update {_user.Username}'s account"
		: "Add new user";

	/// <summary>
	/// The ID of the user to edit, if editing
	/// </summary>
	[Parameter]
    public int? Id { get; set; }

	private void OnLoaded(ViewUserDto user)
	{
		_user = user;
		StateHasChanged();
	}

	private static void OnSuccess(NavigationManager navManager)
	{
		navManager.NavigateTo(DashboardUrls.Users.Index);
	}

	private static void UpdateRole(bool inRole, string role, UpsertUserDto user)
	{
		if (inRole)
		{
			user.Roles.Add(role);
		}
		else
		{
			user.Roles.Remove(role);
		}
	}

}
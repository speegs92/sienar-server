@attribute [Authorize(Roles = Roles.Admin)]
@attribute [Route($"{DashboardUrls.Users.Index}/{{userId:int}}/lock")]
@inject IEntityReadActor<ViewUserDto> UserReader
@inject IEntityReadAllActor<LockoutReasonDto> LockoutReasonReader

@if (_user is null)
{
	<Spinner/>
	return;
}

<NarrowContainer>
	<StandardForm
    	T="LockUserAccountRequest"
    	OnSubmit="@OnSubmit"
    	Title="@($"Lock {_user.Username}'s account")"
    	SubmitText="@($"Lock {_user.Username}'s account")"
    	ThemeColor="Color.Error">
		<Fields>
			<Select
				Label="Select one or more reasons to lock the user out"
				bind-SelectedValues="@_selectedReasons"
				MultiSelection
				ToStringFunc="r => r.Reason">
				@foreach (var reason in _lockoutReasons)
				{
					<MudSelectItem Value="reason"/>
				}
			</Select>
			<MudRadioGroup
				T="LockDuration"
				Class="mt-4"
				Value="_lockDuration"
				ValueChanged="UpdateLockDuration">
				<Radio
					T="LockDuration"
					Value="@LockDuration.OneDay">
					One day
				</Radio>
				<Radio
					T="LockDuration"
					Value="@LockDuration.OneWeek">
					One week
				</Radio>
				<Radio
					T="LockDuration"
					Value="@LockDuration.OneMonth">
					One month
				</Radio>
				<Radio
					T="LockDuration"
					Value="@LockDuration.OneYear">
					One year
				</Radio>
				<Radio
					T="LockDuration"
					Value="@LockDuration.Permanent">
					Permanently
				</Radio>
				<Radio
					T="LockDuration"
					Value="@LockDuration.Custom">
					<MudDatePicker
						Label="Select a date"
						bind-Date="_lockEnd"
						Disabled="_lockDuration != LockDuration.Custom"/>
				</Radio>
			</MudRadioGroup>
		</Fields>

		<MoreActions>
			<MudButton
				Color="Color.Primary"
				Href="@DashboardUrls.Users.Index"
				Variant="Variant.Outlined">
				Back to users listing
			</MudButton>
		</MoreActions>
	</StandardForm>
</NarrowContainer>

@code {

	private ViewUserDto? _user;
	private IEnumerable<LockoutReasonDto> _lockoutReasons = [];
	private LockDuration _lockDuration = LockDuration.OneDay;
	private DateTime? _lockEnd = DateTime.Now.AddDays(1);
	private IEnumerable<LockoutReasonDto> _selectedReasons = [];

	/// <summary>
	/// The ID of the user to lock
	/// </summary>
	[Parameter]
	public int UserId { get; set; }

	[Inject]
	private INotifier Notifier { get; set; } = null!;

	[Inject]
	private ILogger<LockUser> Logger { get; set; } = null!;

	/// <inheritdoc />
	protected override async Task OnInitializedAsync()
	{
		_user = (await UserReader.Read(UserId)).Result;
		if (_user is null)
		{
			Notifier.Error(CoreErrors.Account.NotFound);
			return;
		}

		_lockoutReasons = (await LockoutReasonReader.Read(Filter.GetAll())).Result?.Items ?? [];
	}

	private async Task OnSubmit(
		IStatusActor<LockUserAccountRequest> lockAccountActor,
		LockUserAccountRequest request,
		NavigationManager navManager)
	{
		request.UserId = UserId;

		var selectedReasons = _selectedReasons
			.Select(r => r.Id)
			.ToList();
		if (selectedReasons.Count == 0)
		{
			Notifier.Error($"You must select at least one reason to lock {_user!.Username}'s account");
			return;
		}
		request.Reasons = selectedReasons;

		if (!_lockEnd.HasValue)
		{
			Notifier.Error("You must select a date for the lockout to end. If you want the lockout to be permanent, select \"permanent\"");
			return;
		}

		request.EndDate = _lockEnd.Value;

		var result = await lockAccountActor.Execute(request);

		if (result.Status is OperationStatus.Success)
		{
			navManager.NavigateTo(DashboardUrls.Users.Index);
		}
	}

	private void UpdateLockDuration(LockDuration duration)
	{
		Logger.LogInformation("New lock duration: {duration}", duration);
		_lockDuration = duration;
		int days;

		switch (duration)
		{
			case LockDuration.Custom:
				return;
			case LockDuration.Permanent:
				_lockEnd = DateTime.MaxValue;
				return;
			case LockDuration.OneDay:
				days = 1;
				break;
			case LockDuration.OneWeek:
				days = 7;
				break;
			case LockDuration.OneMonth:
				days = 30;
				break;
			default:
				days = 365;
				break;
		}

		_lockEnd = DateTime.Now.AddDays(days);
	}

	enum LockDuration
	{
		OneDay,
		OneWeek,
		OneMonth,
		OneYear,
		Permanent,
		Custom
	}

}
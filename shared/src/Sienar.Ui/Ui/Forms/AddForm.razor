@* ReSharper disable once CheckNamespace *@
@namespace Sienar.Ui

@typeparam T where T : new()
@inherits BaseForm<T>

<StandardForm
	T="T"
	Title="@($"Add new {EntityName}")"
	TitleTag="@TitleTag"
	ThemeColor="ThemeColor"
	Square="Square"
	Icon="@Icon"
	IconTitle="@IconTitle"
	SubmitText="@($"Add {EntityName}")"
	HideSubmit="HideSubmit"
	ResetText="@ResetText"
	ShowReset="ShowReset"
	OnSubmit="@HandleAdd"
	OnReset="@OnReset"
	Information="@Information"
	Fields="@Fields"
	MoreActions="@MoreActions"/>

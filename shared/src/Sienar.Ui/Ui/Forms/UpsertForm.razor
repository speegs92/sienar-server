@* ReSharper disable once CheckNamespace *@
@namespace Sienar.Ui

@typeparam TViewDto where TViewDto : class, new()
@typeparam TUpsertDto where TUpsertDto : class, new()
@inherits BaseForm<TUpsertDto>

@if (EntityId.HasValue)
{
	<UpdateForm
		TViewDto="TViewDto"
		TEditDto="TUpsertDto"
		EntityId="EntityId.Value"
		OnLoaded="@OnLoaded"
		OnSuccess="@OnUpdateSuccess"
		ThemeColor="ThemeColor"
		OnReset="@OnReset"
		MoreActions="@MoreActions"
		Information="@Information"
		TitleTag="@TitleTag"
		ResetText="@ResetText"
		Icon="@Icon"
		IconTitle="@IconTitle"
		ShowReset="ShowReset"
		HideSubmit="HideSubmit"
		Square="Square"
		Fields="@Fields"/>
}
else
{
	<AddForm
		T="TUpsertDto"
		OnSuccess="@OnAddSuccess"
		ThemeColor="ThemeColor"
		OnReset="@OnReset"
		MoreActions="@MoreActions"
		Information="@Information"
		TitleTag="@TitleTag"
		ResetText="@ResetText"
		Icon="@Icon"
		IconTitle="@IconTitle"
		ShowReset="ShowReset"
		HideSubmit="HideSubmit"
		Square="Square"
		Fields="@Fields"/>
}

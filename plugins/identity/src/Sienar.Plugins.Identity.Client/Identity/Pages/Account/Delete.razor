@attribute [Route(DashboardUrls.Account.Delete)]

<NarrowContainer>
	<StandardForm
		T="DeleteAccountRequest"
		OnSubmit="@OnSubmit"
		SubmitText="Delete account forever!"
		Title="Delete account"
		ThemeColor="Color.Error">
		<Information>
			<MudText>
				Are you sure you want to delete your account? This cannot be undone! Enter your password to confirm you wish to proceed.
			</MudText>
		</Information>

		<Fields>
			<Textbox
				@bind-Value="@context.Password"
				For="() => context.Password"
				Label="Password"
				InputType="InputType.Password"/>
		</Fields>
	</StandardForm>
</NarrowContainer>

@code {

	private static async Task OnSubmit(
		IStatusService<DeleteAccountRequest> deleteAccountService,
		DeleteAccountRequest request,
		NavigationManager navManager)
	{
		var result = await deleteAccountService.Execute(request);

		if (result.Status is OperationStatus.Success)
		{
			navManager.NavigateTo(DashboardUrls.Account.Deleted);
		}
	}

}
@attribute [AllowAnonymous]
@attribute [Route(DashboardUrls.Account.Login)]

<DocTitle Title="Log in"/>

<NarrowContainer>
	<StandardForm
		TFormModel="LoginRequest"
		OnSubmit="@OnSubmit"
		SubmitText="Log in"
		Title="Log in">
		<Fields>
			<Textbox
				@bind-Value="@context.AccountName"
				For="() => context.AccountName"
				Label="Username or email address"/>
			<Textbox
				@bind-Value="@context.Password"
				For="() => context.Password"
				InputType="InputType.Password"
				Label="Password"/>
			<Checkbox
				Class="mt-4"
				Color="Color.Primary"
				UncheckedColor="Color.Default"
				@bind-Value="@context.RememberMe"
				For="() => context.RememberMe"
				Label="Remember me"/>
			<Honeypot @bind-Value="@context.SecretKeyField"/>
		</Fields>

		<MoreActions>
			<MudButton
				Color="Color.Secondary"
				Variant="Variant.Outlined"
				Href="@DashboardUrls.Account.ForgotPassword.Index">
				I forgot my password
			</MudButton>
		</MoreActions>
	</StandardForm>
</NarrowContainer>

@code {

	/// <summary>
	/// An optional URL that the user should be returned to after successfully logging in
	/// </summary>
	[Parameter]
	[SupplyParameterFromQuery]
	public string? ReturnUrl { get; set; }

	private async Task OnSubmit(
		IService<LoginRequest, LoginResult> loginService,
		NavigationManager navManager,
		LoginRequest request)
	{
		var result = await loginService.Execute(request);
		if (result.Status is OperationStatus.Success)
		{
			var destination = ReturnUrl ?? DashboardUrls.Index;
			navManager.NavigateTo(destination);
		}
		else
		{
			var loginResult = result.Result;
			if (loginResult is null)
			{
				return;
			}

			navManager.NavigateTo($"{DashboardUrls.Account.Locked}?userId={loginResult.UserId}&verificationCode={loginResult.VerificationCode}");
		}
	}

}
@attribute [AllowAnonymous]
@attribute [Route(DashboardUrls.Account.Register.Index)]

<DocTitle Title="Register"/>

<NarrowContainer>
	<StandardForm
		T="RegisterRequest"
		OnSubmit="@OnSubmit"
		Title="Register"
		SubmitText="Register"
		ShowReset>
    	<Fields>
		    <Textbox
			    @bind-Value="@context.Username"
			    For="() => context.Username"
			    Label="Username"
			    HelperText="Your username should be between 6 and 32 characters long. It should only contain letters, numbers, underscores, and periods."/>

		    <Textbox
			    @bind-Value="@context.Email"
			    For="() => context.Email"
			    InputType="InputType.Email"
			    Label="Email address"
			    HelperText="You need an email address to verify your account."/>

		    <Textbox
			    @bind-Value="@context.Password"
			    For="() => context.Password"
			    InputType="InputType.Password"
			    Label="Password"
			    HelperText="Your password should be between 8 and 64 characters long. It should contain a mix of uppercase and lowercase letters, numbers, and special characters."/>

		    <Textbox
			    @bind-Value="@context.ConfirmPassword"
			    For="() => context.ConfirmPassword"
			    InputType="InputType.Password"
			    Label="Confirm password"/>

    		<Honeypot @bind-Value="@context.SecretKeyField"/>

		    <Checkbox
			    @bind-Value="@context.AcceptTos"
			    For="() => context.AcceptTos">
    			I accept the Terms of Service and Privacy Policy
    		</Checkbox>
    	</Fields>
    </StandardForm>
</NarrowContainer>


@code {

	private static async Task OnSubmit(
		IStatusService<RegisterRequest> registerService,
		NavigationManager navManager,
		RegisterRequest request)
	{
		var result = await registerService.Execute(request);

		if (result.Status is OperationStatus.Success)
		{
			navManager.NavigateTo($"{DashboardUrls.Account.Register.Successful}?username={request.Username}&email={request.Email}");
		}
	}

}
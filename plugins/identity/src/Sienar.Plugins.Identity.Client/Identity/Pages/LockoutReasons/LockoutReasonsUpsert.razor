@attribute [Authorize(Roles = Roles.Admin)]
@attribute [Route(DashboardUrls.LockoutReasons.Add)]
@attribute [Route($"{DashboardUrls.LockoutReasons.Index}/{{id:int}}")]

<DocTitle Title="@Title"/>

<NarrowContainer>
	<UpsertForm
		TViewDto="LockoutReasonDto"
		TUpsertDto="LockoutReasonDto"
		EntityId="Id"
		For="@(_ => "reason")"
		OnUpdateSuccess="OnSuccess"
		OnLoaded="OnLoaded">
		<Fields>
			<MudTextField
				@bind-Value="@context.Reason"
				For="() => context.Reason"
				Label="Lockout reason"
				MaxLines="3"
				Counter="250"
				MaxLength="250"
				AutoGrow
				Immediate/>
		</Fields>

		<MoreActions>
			<MudButton
				Color="Color.Secondary"
				Variant="Variant.Outlined"
				Href="@DashboardUrls.LockoutReasons.Index">
				Back to reasons listing
			</MudButton>
		</MoreActions>
	</UpsertForm>
</NarrowContainer>

@code {

	private LockoutReasonDto? _reason;

	private string Title => _reason is null
		? "Add new lockout reason"
		: "Update lockout reason";

	/// <summary>
	/// The ID of the lockout reason to update, if updating
	/// </summary>
	[Parameter]
	public int? Id { get; set; }

	private void OnLoaded(LockoutReasonDto reason)
	{
		_reason = reason;
		StateHasChanged();
	}

	private void OnSuccess(NavigationManager navManager)
	{
		navManager.NavigateTo(DashboardUrls.LockoutReasons.Index);
	}

}